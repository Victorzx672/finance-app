generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int      @id @default(autoincrement())
  usuario  String   @unique
  senha    String
  criadoEm DateTime @default(now())

  finances FinanceData[]
}

model FinanceData {
  id                     Int      @id @default(autoincrement())
  mesReferencia          String
  renda                  Float    @default(0)
  gastosFixos            Float    @default(0)
  gastosVariaveis        Float    @default(0)
  percentualInvestimento Float    @default(0)
  meta                   Float    @default(0)
  criadoEm               DateTime @default(now())
  atualizadoEm           DateTime @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id])

  gastos Expense[]

  @@unique([userId, mesReferencia])
}

model Expense {
  id    Int    @id @default(autoincrement())
  nome  String
  valor Float

  financeId Int
  finance   FinanceData @relation(fields: [financeId], references: [id], onDelete: Cascade)
}